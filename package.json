{
  "name": "docker-fastify-boilerplate",
  "version": "4.0.0",
  "description": "Node.js RESTful API boilerplate using Docker, Docker Compose, Fastify and Mongodb",
  "main": "src/index.js",
  "scripts": {
    "dev": "./node_modules/nodemon/bin/nodemon.js -r dotenv/config src/index.js",
    "prepare": "git config core.hooksPath .hooks",
    "start": "node src/index.js",
    "standard:fix": "standard --fix",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pinceladasdaweb/docker-fastify-boilerplate.git"
  },
  "keywords": [
    "docker",
    "api",
    "fastify",
    "mongdb"
  ],
  "author": "Pedro Rogério",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pinceladasdaweb/docker-fastify-boilerplate/issues"
  },
  "homepage": "https://github.com/pinceladasdaweb/docker-fastify-boilerplate#readme",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.1.0",
    "lint-staged": "^17.1.0",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "standard": "^17.1.2"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^10.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@sentry/node": "^10.67.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "ajv-keywords": "^5.1.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "http-errors": "^2.0.1",
    "mongoose": "^9.8.0",
    "mongoose-delete": "^1.0.7",
    "mongoose-paginate-v2": "^1.9.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "lint-staged": {
    "{src,test}/**/*.js": "standard"
  }
}
